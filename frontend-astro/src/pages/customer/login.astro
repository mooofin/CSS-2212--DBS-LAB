---
import MainLayout from '../../layouts/MainLayout.astro';
import CustomerLogin from '../../components/react/CustomerLogin';
import { ToastProvider } from '../../components/ui/Toast';
---

<MainLayout title="Guest Login">
  <ToastProvider client:load>
    <CustomerLogin client:load />
  </ToastProvider>
</MainLayout>

<style is:global>
  /* Override main layout sidebar for login */
  aside { display: none !important; }
  main { margin-left: 0 !important; padding: 0 !important; width: 100% !important; margin-top: 0 !important; }
</style>
