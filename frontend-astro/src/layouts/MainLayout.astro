---
import '@/index.css';
import { Hotel, LayoutDashboard, BedDouble, Users, CalendarRange, IndianRupee, UserCog, Settings, HelpCircle, LogOut, Search } from 'lucide-react';
import { ModeToggle } from '@/components/react/ModeToggle';

export interface Props {
  title: string;
  user?: any;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Grand Stay</title>
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      };
      
      const theme = getTheme();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-background text-foreground antialiased selection:bg-primary/20 transition-colors duration-500">
    <div id="app-root" class="flex h-screen overflow-hidden">
      {/* Sidebar — Premium Luxury Design */}
      <aside class="w-80 flex flex-col gap-0 bg-sidebar text-sidebar-foreground m-4 mr-0 rounded-3xl border border-sidebar-border shadow-[0_8px_32px_rgba(0,0,0,0.1)] dark:shadow-[0_8px_32px_rgba(0,0,0,0.4)] shrink-0 overflow-hidden stagger-1 relative">
        {/* Sidebar accent line */}
        <div class="absolute left-0 top-0 w-1 h-full bg-gradient-to-b from-sidebar-primary via-sidebar-primary/60 to-transparent"></div>
        
        <div class="px-8 py-10 flex items-center gap-4 relative">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-sidebar-primary via-sidebar-accent to-sidebar-primary flex items-center justify-center shadow-2xl shadow-sidebar-primary/30 relative overflow-hidden group">
            <div class="absolute inset-0 bg-shimmer opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <Hotel size={26} class="text-sidebar-primary-foreground relative z-10" />
          </div>
          <div>
            <h1 class="text-2xl font-bold leading-none font-heading tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-sidebar-primary to-sidebar-accent">Grand Stay</h1>
            <p class="text-[11px] text-sidebar-foreground/60 mt-2 uppercase tracking-[0.25em] font-semibold">Management Portal</p>
          </div>
        </div>

        <div class="h-px bg-gradient-to-r from-transparent via-sidebar-primary/30 to-transparent mx-8"></div>

        <nav class="flex-1 px-6 py-6 space-y-2 overflow-y-auto">
          <p class="px-5 pb-3 pt-4 text-[10px] font-bold text-sidebar-primary uppercase tracking-[0.2em] opacity-70">Main Menu</p>
          <a href="/dashboard" class="block group">
            <button class="w-full flex items-center gap-4 px-5 py-3.5 text-sm rounded-2xl hover:bg-sidebar-accent transition-all duration-300 text-sidebar-foreground/70 hover:text-sidebar-foreground font-medium border border-transparent hover:border-sidebar-border hover:shadow-lg hover:shadow-sidebar-primary/5 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-sidebar-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
              <LayoutDashboard size={18} class="opacity-60 group-hover:opacity-100 transition-opacity relative z-10" /> 
              <span class="relative z-10">Dashboard</span>
            </button>
          </a>
          <a href="/rooms" class="block group">
            <button class="w-full flex items-center gap-4 px-5 py-3.5 text-sm rounded-2xl hover:bg-sidebar-accent transition-all duration-300 text-sidebar-foreground/70 hover:text-sidebar-foreground font-medium border border-transparent hover:border-sidebar-border hover:shadow-lg hover:shadow-sidebar-primary/5 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-sidebar-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
              <BedDouble size={18} class="opacity-60 group-hover:opacity-100 transition-opacity relative z-10" /> 
              <span class="relative z-10">Rooms</span>
            </button>
          </a>
          <a href="/guests" class="block group">
            <button class="w-full flex items-center gap-4 px-5 py-3.5 text-sm rounded-2xl hover:bg-sidebar-accent transition-all duration-300 text-sidebar-foreground/70 hover:text-sidebar-foreground font-medium border border-transparent hover:border-sidebar-border hover:shadow-lg hover:shadow-sidebar-primary/5 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-sidebar-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
              <Users size={18} class="opacity-60 group-hover:opacity-100 transition-opacity relative z-10" /> 
              <span class="relative z-10">Guests</span>
            </button>
          </a>
          <a href="/bookings" class="block group">
            <button class="w-full flex items-center gap-4 px-5 py-3.5 text-sm rounded-2xl hover:bg-sidebar-accent transition-all duration-300 text-sidebar-foreground/70 hover:text-sidebar-foreground font-medium border border-transparent hover:border-sidebar-border hover:shadow-lg hover:shadow-sidebar-primary/5 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-sidebar-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
              <CalendarRange size={18} class="opacity-60 group-hover:opacity-100 transition-opacity relative z-10" /> 
              <span class="relative z-10">Bookings</span>
            </button>
          </a>
          
          <span id="admin-links">
             <p class="px-5 pb-3 pt-8 text-[10px] font-bold text-sidebar-primary uppercase tracking-[0.2em] opacity-70">Administrator</p>
             <a href="/billing" class="block group">
                <button class="w-full flex items-center gap-4 px-5 py-3.5 text-sm rounded-2xl hover:bg-sidebar-accent transition-all duration-300 text-sidebar-foreground/70 hover:text-sidebar-foreground font-medium border border-transparent hover:border-sidebar-border hover:shadow-lg hover:shadow-sidebar-primary/5 relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-sidebar-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                  <IndianRupee size={18} class="opacity-60 group-hover:opacity-100 transition-opacity relative z-10" /> 
                  <span class="relative z-10">Billing</span>
                </button>
              </a>
              <a href="/staff" class="block group">
                <button class="w-full flex items-center gap-4 px-5 py-3.5 text-sm rounded-2xl hover:bg-sidebar-accent transition-all duration-300 text-sidebar-foreground/70 hover:text-sidebar-foreground font-medium border border-transparent hover:border-sidebar-border hover:shadow-lg hover:shadow-sidebar-primary/5 relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-sidebar-primary/5 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                  <UserCog size={18} class="opacity-60 group-hover:opacity-100 transition-opacity relative z-10" /> 
                  <span class="relative z-10">Staff</span>
                </button>
              </a>
          </span>
        </nav>

        <div class="px-6 py-5 space-y-2">
          <button class="w-full flex items-center gap-3 px-5 py-2.5 text-xs rounded-xl hover:bg-sidebar-accent transition-all text-sidebar-foreground/60 hover:text-sidebar-foreground font-medium">
            <Settings size={16} class="opacity-60" /> Settings
          </button>
          <button class="w-full flex items-center gap-3 px-5 py-2.5 text-xs rounded-xl hover:bg-sidebar-accent transition-all text-sidebar-foreground/60 hover:text-sidebar-foreground font-medium">
            <HelpCircle size={16} class="opacity-60" /> Help Support
          </button>
        </div>

        <div class="h-px bg-gradient-to-r from-transparent via-sidebar-primary/30 to-transparent mx-8"></div>

        <div class="p-6 bg-sidebar-accent/30 backdrop-blur-sm">
          <div class="flex items-center gap-4 px-2">
            <div id="user-avatar" class="w-11 h-11 rounded-2xl bg-gradient-to-br from-sidebar-primary/20 to-sidebar-accent/20 border-2 border-sidebar-primary/30 flex items-center justify-center text-base font-bold text-sidebar-primary shadow-inner shadow-sidebar-primary/20">A</div>
            <div class="flex-1 min-w-0">
              <p id="username" class="text-sm font-bold leading-none truncate capitalize tracking-tight">User</p>
              <p id="user-role" class="text-[10px] text-sidebar-foreground/60 truncate mt-2 uppercase font-semibold tracking-[0.15em] opacity-60">Guest</p>
            </div>
            <button id="logout-btn" class="h-10 w-10 flex items-center justify-center rounded-xl text-sidebar-foreground/60 hover:bg-destructive/20 hover:text-destructive transition-all duration-300 hover:scale-105">
              <LogOut size={16} />
            </button>
          </div>
        </div>
      </aside>

      {/* Main Content — Premium Design */}
      <main class="flex-1 overflow-hidden m-4 rounded-3xl border border-border bg-card/50 backdrop-blur-xl shadow-[0_8px_32px_rgba(0,0,0,0.05)] dark:shadow-[0_8px_32px_rgba(0,0,0,0.4)] relative flex flex-col stagger-2">
        {/* Decorative corner accent */}
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-primary/5 to-transparent rounded-full blur-3xl pointer-events-none"></div>
        
        <header class="flex items-center gap-4 border-b border-border px-10 h-20 shrink-0 sticky top-0 bg-background/40 backdrop-blur-2xl z-20 relative">
          <div class="h-6 w-px bg-gradient-to-b from-transparent via-primary/40 to-transparent"></div>
          <div class="flex items-center gap-4 flex-1 relative">
            <Search size={18} class="text-muted-foreground/40" />
            <input 
              class="bg-transparent border-none outline-none text-sm text-foreground w-full placeholder:text-muted-foreground/40 font-medium focus:placeholder:text-muted-foreground/60 transition-all" 
              placeholder="Search across all modules..." 
            />
          </div>
          <div class="flex items-center gap-5">
            <ModeToggle client:load />
            <div class="h-10 w-10 rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 animate-pulse border border-border shadow-inner"></div>
          </div>
        </header>

        <div class="flex-1 overflow-y-auto px-10 py-8 md:px-14 md:py-12 relative z-10">
           <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      const user = JSON.parse(localStorage.getItem('user') || 'null');
      const publicPaths = ['/login', '/customer/login'];

      if (!user && !publicPaths.includes(window.location.pathname)) {
        window.location.replace('/login');
      }

      if (user) {
        // Populate sidebar user info
        const usernameEl = document.getElementById('username');
        const roleEl = document.getElementById('user-role');
        const avatarEl = document.getElementById('user-avatar');
        if (usernameEl) usernameEl.textContent = user.username;
        if (roleEl) roleEl.textContent = user.role;
        if (avatarEl) avatarEl.textContent = (user.username || '?')[0].toUpperCase();

        // Hide admin-only links for non-admin roles
        if (user.role !== 'admin') {
          const adminLinks = document.getElementById('admin-links');
          if (adminLinks) adminLinks.style.display = 'none';
        }

        // Customers should NOT be on staff pages — redirect them
        const staffOnlyPaths = ['/dashboard', '/rooms', '/guests', '/bookings', '/billing', '/staff'];
        if (user.role === 'customer') {
          if (staffOnlyPaths.includes(window.location.pathname)) {
            window.location.replace('/customer/dashboard');
          }
        }
      }

      const logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.onclick = () => {
          const isCustomer = user?.role === 'customer';
          localStorage.removeItem('user');
          window.location.replace(isCustomer ? '/customer/login' : '/login');
        };
      }
    </script>
  </body>
</html>
